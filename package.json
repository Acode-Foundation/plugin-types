{
	"name": "acode-plugin-types",
	"description": "TypeScript declarations for Acode's public plugin API.",
	"version": "1.12.4",
	"types": "index.d.ts",
	"packageManager": "bun@1.3.1",
	"author": {
		"name": "Acode Foundation",
		"email": "contact@acode.app"
	},
	"readme": "README.md",
	"repository": {
		"url": "git+https://github.com/Acode-Foundation/plugin-types.git"
	},
	"homepage": "https://docs.acode.app/docs/getting-started/intro",
	"scripts": {
		"build": "bun run ./scripts/sync-references.ts",
		"lint": "biome check",
		"format": "biome format --write",
		"typecheck": "tsc -p tsconfig.json",
		"test": "bun run typecheck",
		"check": "bun run build && bun run lint && bun run typecheck",
		"link-types": "bun run ./scripts/sync-references.ts",
		"prepublishOnly": "bun run check"
	},
	"files": [
		"./src",
		"./types",
		"./index.d.ts",
		"README.md",
		"THIRD_PARTY_NOTICES.md"
	],
	"keywords": ["acode", "plugin-types", "acode-app"],
	"license": "MIT",
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.3",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/language": "^6.12.3",
		"@codemirror/lint": "^6.9.7",
		"@codemirror/search": "^6.7.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.0",
		"@lezer/highlight": "^1.2.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"typescript": "^5.9.3"
	}
}
